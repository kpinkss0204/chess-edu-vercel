{
  "functions": {
    "api/lichess-proxy.js": {
      "maxDuration": 30
    },
    "api/lichess-token.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/lichess-proxy", "destination": "/api/lichess-proxy.js" },
    { "source": "/api/lichess-token", "destination": "/api/lichess-token.js" },
    { "source": "/favicon.ico", "destination": "/favicon.svg" },
    { "source": "/(.*\\.html)", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
